{
  "openapi": "3.0.3",
  "info": {
    "title": "Products CRUD API",
    "version": "1.0.0",
    "description": "API para gestión de productos. Endpoints públicos: GET. Endpoints protegidos requieren header x-api-key."
  },
  "servers": [
    { "url": "/" }
  ],
  "paths": {
    "/api/items": {
      "get": {
        "summary": "Listar artículos (PÚBLICO)",
        "responses": {
          "200": {
            "description": "Lista de artículos"
          }
        }
      },
      "post": {
        "summary": "Crear artículo",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "201": { "description": "Creado" },
          "401": { "description": "API key requerida" }
        }
      }
    },
    "/api/items/{id}": {
      "get": {
        "summary": "Obtener artículo por ID (PÚBLICO)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Artículo encontrado" },
          "404": { "description": "No encontrado" }
        }
      },
      "put": {
        "summary": "Actualizar artículo completo",
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Actualizado" },
          "401": { "description": "API key requerida" }
        }
      },
      "patch": {
        "summary": "Actualizar artículo parcialmente",
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Actualizado" },
          "401": { "description": "API key requerida" }
        }
      },
      "delete": {
        "summary": "Eliminar artículo",
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "204": { "description": "Eliminado" },
          "401": { "description": "API key requerida" }
        }
      }
    },
    "/api/maintenance/health": {
      "get": {
        "summary": "Verificar estado de BD (PÚBLICO)",
        "responses": {
          "200": { "description": "BD operativa" }
        }
      }
    },
    "/api/maintenance/ml-import": {
      "post": {
        "summary": "Importar de MercadoLibre",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": { "description": "Importación completada" },
          "401": { "description": "API key requerida" }
        }
      }
    },
    "/api/maintenance/import": {
      "post": {
        "summary": "Importar JSON genérico",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": { "description": "Importación completada" },
          "401": { "description": "API key requerida" }
        }
      }
    },
    "/api/maintenance/cleanup": {
      "delete": {
        "summary": "Limpiar todos los productos",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": { "description": "Limpiado" },
          "401": { "description": "API key requerida" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  }
}
